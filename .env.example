JWT_SECRET=YOUR_JWT_SECRET_MIN_256_BITS

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=YOUR_EMAIL
MAIL_PASSWORD=YOUR_APP_PASSWORD
MAIL_FROM=YOUR_EMAIL

CLOUDINARY_CLOUD_NAME=YOUR_KEY
CLOUDINARY_API_KEY=YOUR_KEY
