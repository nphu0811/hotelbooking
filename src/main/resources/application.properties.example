spring.application.name=HotelBooking

spring.datasource.url=${SPRING_DATASOURCE_URL:${DATABASE_URL:${DATABASE_PUBLIC_URL:YOUR_RAILWAY_POSTGRES_URL}}}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME:${DATABASE_USERNAME:YOUR_DB_USERNAME}}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:${DATABASE_PASSWORD:YOUR_DB_PASSWORD}}
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.jdbc.time_zone=UTC

spring.jackson.time-zone=UTC
logging.pattern.dateformat=yyyy-MM-dd'T'HH:mm:ss.SSSXXX,UTC

spring.flyway.enabled=true

app.jwt.secret=${JWT_SECRET:YOUR_JWT_SECRET_MIN_256_BITS}
app.jwt.access-token-ttl-minutes=60
app.jwt.refresh-token-ttl-days=7
app.public-base-url=${APP_PUBLIC_BASE_URL:http://localhost:8080}

cloudinary.cloud-name=${CLOUDINARY_CLOUD_NAME:YOUR_KEY}
cloudinary.api-key=${CLOUDINARY_API_KEY:YOUR_KEY}
cloudinary.api-secret=${CLOUDINARY_API_SECRET:YOUR_KEY}

mail.from=${MAIL_FROM:YOUR_EMAIL}
brevo.api-key=${BREVO_API_KEY:}
brevo.sms.sender=${BREVO_SMS_SENDER:HotelBook}

vnpay.tmn-code=${VNPAY_TMN_CODE:YOUR_KEY}
vnpay.hash-secret=${VNPAY_HASH_SECRET:YOUR_KEY}
vnpay.pay-url=${VNPAY_PAY_URL:YOUR_SANDBOX_URL}
vnpay.return-url=${VNPAY_RETURN_URL:YOUR_RETURN_URL}
vnpay.ipn-url=${VNPAY_IPN_URL:YOUR_IPN_URL}

maps.provider=${MAPS_PROVIDER:leaflet}
google.maps.api-key=${GOOGLE_MAPS_API_KEY:YOUR_KEY}
google.places.api-key=${GOOGLE_PLACES_API_KEY:YOUR_KEY}
google.places.enabled=${GOOGLE_PLACES_ENABLED:false}
geoapify.api-key=${GEOAPIFY_API_KEY:YOUR_KEY}
geoapify.enabled=${GEOAPIFY_ENABLED:false}
hoteldata.overpass.endpoint=${HOTELDATA_OVERPASS_ENDPOINT:https://overpass-api.de/api/interpreter}
